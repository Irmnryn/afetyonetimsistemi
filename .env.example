# API documentation says the backend runs at http://localhost:8080.
VITE_FRONTEND_PORT=5173
VITE_BACKEND_URL=https://human-evacuee-thieving.ngrok-free.dev

# Leave empty to use the Vite /api proxy in development.
# Set this only when the frontend must call a public backend directly.
VITE_API_BASE_URL=

# Set true only when you want local demo data instead of real API failures.
VITE_USE_DEMO_DATA=false
